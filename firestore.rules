rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null &&
             request.auth.token.email.lower() == 'marcelinhofb2011@gmail.com';
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && getUserData().get('role', '') == 'ADMIN');
    }

    function isCoordinator() {
      let data = getUserData();
      return isMasterAdmin() || (isSignedIn() && data.get('role', '') in ['ADMIN', 'COORDINATOR']);
    }

    function canSell() {
      let data = getUserData();
      return isCoordinator() || (isSignedIn() && data.get('canSell', false) == true);
    }

    function getExistingData() {
       return resource.data;
    }

    function isSameCongregation(congregationId) {
      let data = getUserData();
      return isAdmin() || (isSignedIn() && data.get('congregationId', '') == congregationId);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isCoordinator());
      allow list: if isCoordinator();
      allow write: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (
        isCoordinator() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('congregationId', '') != '' &&
        existing().get('congregationId', '') == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('congregationId', '') &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['canSell'])
      );
      allow delete: if isAdmin();
    }

    match /congregations/{congId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /buses/{busId} {
      allow read: if isSignedIn();
      allow create: if isCoordinator(); 
      allow update, delete: if isAdmin() || isSameCongregation(existing().get('congregationId', ''));
    }

    match /reservations/{resId} {
      // Allow list for anyone signed in to check occupancy
      allow list: if isSignedIn();
      
      allow get: if isSignedIn() && (
        isAdmin() || 
        isSameCongregation(resource.data.congregationId) || 
        resource.data.createdBy == request.auth.uid
      );

      allow create: if isSignedIn() && canSell() &&
                    request.resource.data.createdBy == request.auth.uid &&
                    request.resource.data.amountPaid is number &&
                    request.resource.data.totalValue is number;

      allow update: if isSignedIn() && (
        isAdmin() || 
        isSameCongregation(existing().congregationId) || 
        existing().createdBy == request.auth.uid
      );

      allow delete: if isAdmin() || isSameCongregation(existing().congregationId);
    }

    match /audit_logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (getUserData().get('role', 'USER') in resource.data.get('targetRoles', []) && 
         (!resource.data.keys().hasAny(['congregationId']) || resource.data.congregationId == getUserData().get('congregationId', '')))
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (getUserData().get('role', 'USER') in existing().get('targetRoles', []) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']))
      );
    }

    match /passengers_history/{passengerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && canSell();
    }

    function existing() { return resource.data; }
  }
}
