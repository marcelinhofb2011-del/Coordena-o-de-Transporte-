rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      // Direct comparison with lower() for safety
      return isSignedIn() && 
             request.auth.token.email.lower() == 'marcelinhofb2011@gmail.com';
    }

    function isAdmin() {
      // Direct check to avoid recursion if possible, but keep it robust
      return isMasterAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN');
    }

    function isCoordinator() {
      return isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'COORDINATOR');
    }

    function canSell() {
      return isCoordinator() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('canSell', false) == true);
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSameCongregation(congregationId) {
      return isAdmin() || 
             (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().congregationId == congregationId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    match /congregations/{congId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /buses/{busId} {
      allow read: if isSignedIn();
      allow create: if isCoordinator(); 
      allow update, delete: if isAdmin() || isSameCongregation(existing().get('congregationId', ''));
    }

    match /reservations/{resId} {
      // GET: Single document access
      allow get: if isSignedIn() && (
        isAdmin() || 
        isSameCongregation(resource.data.congregationId) || 
        resource.data.createdBy == request.auth.uid
      );
      
      // LIST: Query enforcement.
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.createdBy == request.auth.uid ||
        isSameCongregation(resource.data.congregationId)
      );

      allow create: if isSignedIn() && canSell() &&
                    request.resource.data.createdBy == request.auth.uid &&
                    request.resource.data.amountPaid is number &&
                    request.resource.data.totalValue is number;

      allow update: if isSignedIn() && (
        isAdmin() || 
        isSameCongregation(existing().congregationId) || 
        existing().createdBy == request.auth.uid
      );

      allow delete: if isAdmin() || isSameCongregation(existing().congregationId);
    }

    match /audit_logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if isSignedIn();
    }

    function existing() { return resource.data; }
  }
}
